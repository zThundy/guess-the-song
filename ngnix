server {
    listen 80;
    server_name sg.ebalsamo.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name sg.ebalsamo.com;

    ssl_certificate /etc/letsencrypt/live/sg.ebalsamo.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/sg.ebalsamo.com/privkey.pem;

    root /var/www/sg;
    index index.html;

    # React frontend
    location / {
        try_files $uri /index.html;
    }

    # =========================
    # NODE API + WEBSOCKET
    # =========================
    # API routes (HTTP only)
    location /api/ {
        proxy_pass https://127.0.0.1:8443/;

        proxy_ssl_verify off;

        proxy_http_version 1.1;

        # pass-through headers for API
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 86400;
    }

    # Dedicated WebSocket route - separate from /api
    location /socket {
        proxy_pass https://127.0.0.1:8443/;

        proxy_ssl_verify off;

        proxy_http_version 1.1;

        # websocket / wss upgrade
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Sec-WebSocket-Protocol $http_sec_websocket_protocol;
        proxy_set_header Sec-WebSocket-Extensions "permessage-deflate; client_max_window_bits";

        # pass-through headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 86400;
    }
}